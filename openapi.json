{
  "openapi": "3.0.0",
  "info": {
    "title": "Task API",
    "version": "1.0.0",
    "description": "A simple CRUD API for managing tasks."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
      "/": {
    "get": {
      "summary": "API information"
    }
  },
  "/health": {
    "get": {
      "summary": "Health check"
    }
  },
  "/tasks": {
    "get": {
      "summary": "Get all tasks"
    },
    "post": {
      "summary": "Create a task"
    }
  },
  "/tasks/{id}": {
    "get": {
      "summary": "Get task by ID"
    },
    "put": {
      "summary": "Update task"
    },
    "delete": {
      "summary": "Delete task"
    }
  }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "done": {
            "type": "boolean"
          }
        }
      }
    }
  }
}